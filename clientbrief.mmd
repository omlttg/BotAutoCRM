flowchart TD
    %% Định nghĩa Style
    classDef partner fill:#f9f,stroke:#333,stroke-width:2px;
    classDef problem fill:#ff9,stroke:#333,stroke-width:2px;
    classDef deliverable fill:#9f9,stroke:#333,stroke-width:2px;
    classDef data fill:#9cf,stroke:#333,stroke-width:2px;
    classDef technical fill:#f96,stroke:#333,stroke-width:2px;
    classDef score fill:#c9f,stroke:#333,stroke-width:2px;

    Root("BotAutoCRM: AI Agent cho CRM (Bank A)")

    %% Trục chính chạy dọc (Top-Down) kết nối các phần
    Root --> PartnerInfo("Phần A & B: Đối tác & Track")
    PartnerInfo --> ProblemDesc("Phần C: Mô tả bài toán")
    ProblemDesc --> Deliverables("Phần D: Kết quả & Bàn giao")
    Deliverables --> Resources("Phần E: Dữ liệu & Tài nguyên")
    Resources --> TechnicalReq("Phần H & I: Yêu cầu kỹ thuật & Kịch bản")
    TechnicalReq --> Scoring("Phần F & G: Tiêu chí & Cam kết")

    %% Các nhánh chi tiết xếp dọc bên dưới các node chính tương ứng
    subgraph Sec_Partner ["Đối tác & Track"]
        direction TB
        PartnerInfo --> P1("Đối tác: Ngân hàng TMCP A<br/>(Tài chính Ngân hàng bán lẻ & doanh nghiệp)"):::partner
        P1 --> P2("Track: Đổi Mới Sáng Tạo<br/>(AI Agent + Model Context Protocol - MCP)"):::partner
    end

    subgraph Sec_Problem ["Mô tả bài toán"]
        direction TB
        ProblemDesc --> PB1("Bối cảnh: CRM API-first với Lead/Opportunity,<br/>Interaction History, Campaign REST APIs"):::problem
        PB1 --> PB2("Vấn đề: RM mất 2-3h/ca xử lý thủ công cho 50-80 KH.<br/>Salesforce/MS Copilot chi phí cao, khó tích hợp nội địa"):::problem
        PB2 --> PB3("Câu hỏi trọng tâm: Cách xây dựng AI Agent tiếng Việt tự nhắc lịch,<br/>soạn email/script, chuyển mạch CRM modules qua MCP"):::problem
    end

    subgraph Sec_Deliverables ["Kết quả & Bàn giao"]
        direction TB
        Deliverables --> D1("KPIs: Độ chính xác >= 85% (demo live);<br/>Giảm >= 50% time soạn email/script;<br/>Chuyển mạch >= 3 CRM contexts không mất data"):::deliverable
        D1 --> D2("Sản phẩm bàn giao: AI Agent Frontend (web chat tiếng Việt),<br/>MCP Server, CRM Simulations (mock data),<br/>Docs & Proposal, Source Code"):::deliverable
        D2 --> D3("Pilot Roadmap: 50 RM tại HN & HCM trong 3 tháng từ 10/2026;<br/>Đạt chuẩn an toàn thông tin & Nghị định 13/2023"):::deliverable
    end

    subgraph Sec_Resources ["Dữ liệu & Tài nguyên"]
        direction TB
        Resources --> R1("CRM Sandbox API: Endpoint sandbox.crm.banka.vn,<br/>mock data 500 KH, Rate limit 100 req/min"):::data
        R1 --> R2("Interaction Dataset: 10.000 bản ghi tương tác tiếng Việt (NDA)"):::data
        R2 --> R3("Templates & Knowledge: 200 email, 150 call scripts,<br/>35 sản phẩm Bank A"):::data
        R3 --> R4("Hỗ trợ bổ sung: AWS $500, PM hỗ trợ,<br/>Senior RM + CRM API Lead hỗ trợ nghiệp vụ/kỹ thuật"):::data
    end

    subgraph Sec_Technical ["Yêu cầu kỹ thuật & Kịch bản"]
        direction TB
        TechnicalReq --> T1("Ngôn ngữ & Ngữ cảnh: Tiếng Việt bắt buộc,<br/>hiểu thuật ngữ viết tắt (KH, ĐNCV, RM, CBNV);<br/>Pháp lý tín dụng, bảo hiểm, KYC Việt Nam"):::technical
        T1 --> T2("Hiệu năng & Bảo mật: Latency <= 5s (câu đơn),<br/><= 15s (phức tạp); Không lưu chat clear text;<br/>Audit log đầy đủ cho mỗi LLM call"):::technical
        T2 --> T3("Tích hợp: Tích hợp Bank A CRM Sandbox (>= 3 endpoints),<br/>chạy local repo sạch, đề xuất kiến trúc proxy LLM"):::technical
    end

    subgraph Sec_Scoring ["Tiêu chí & Cam kết"]
        direction TB
        Scoring --> S1("Tiêu chí đặc thù (25%): MCP Protocol Implementation (15%) -<br/>giữ trạng thái khi đổi module; CRM Integration Depth (10%) -<br/>đọc từ >= 3 endpoints tổng hợp phản hồi có nguồn gốc"):::score
        S1 --> S2("Cam kết đối tác: Pilot 3 tháng hỗ trợ $5K; tuyển dụng AI Engineer;<br/>Hỗ trợ domain expert onsite/online"):::score
    end

