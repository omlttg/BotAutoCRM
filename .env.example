# Cấu hình biến môi trường cho BotAutoCRM Co-Pilot
# Sao chép file này thành file .env và điền thông tin của bạn.

# Khóa API Gemini chính thức của bạn (để chạy chế độ online)
GEMINI_API_KEY=

# Chế độ chạy ngoại tuyến (offline)
# Đặt thành true để sử dụng Mock CRM + Mock LLM mà không cần kết nối mạng hay API key
# Đặt thành false để kết nối đến API CRM thật và Gemini API
OFFLINE_MODE=false

# Địa chỉ máy chủ CRM Sandbox của Ngân hàng TMCP A
CRM_BASE_URL=https://sandbox.crm.banka.vn

# Các khóa API dự phòng (tùy chọn - phục vụ LLM Router tự động chuyển mạch)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_URL=http://localhost:11434/api/chat
